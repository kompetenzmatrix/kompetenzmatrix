[{{ range $index, $page := .Site.Pages }}
{{- if ne $page.Type "json" -}}
{{- /* Modul-Unterseiten (Umsetzungsvorschlag, Handlungssituationen, …) NICHT indexieren,
       damit eine Suche nach der Modulnummer nur die Modul-Hauptseite zurückgibt. */ -}}
{{- $isSub := false -}}
{{- with $page.Parent }}{{ if .Params.modul }}{{ $isSub = true }}{{ end }}{{ end -}}
{{- if $isSub -}}
{{- else -}}
{{- if and $index (gt $index 0) -}},{{- end }}
{
	"uri": "{{ $page.Permalink }}",
	"title": "{{ htmlEscape $page.Title}}",
	"tags": [{{ range $tindex, $tag := $page.Params.tags }}{{ if $tindex }}, {{ end }}"{{ $tag| htmlEscape }}"{{ end }}],
	"description": "{{ htmlEscape .Description}}",
	"content": {{$page.Plain | jsonify}}
}
{{- end -}}
{{- end -}}
{{- end -}}]
